---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
  const modules = import.meta.glob("/src/content/blog/*.md", { eager: true });
  return Object.values(modules)
    .map((mod) => mod.frontmatter?.slug)
    .filter(Boolean)
    .map((slug) => ({ params: { slug } }));
}

const modules = import.meta.glob("/src/content/blog/*.md", { eager: true });
const postModule = Object.values(modules).find(
  (mod) => mod.frontmatter?.slug === Astro.params.slug
);
if (!postModule) {
  throw new Error(`Post not found for slug: ${Astro.params.slug}`);
}
const { Content, frontmatter } = postModule;

const seo = {
  title: `${frontmatter.title} | Blog | CA Articleship Portfolio`,
  description: frontmatter.summary
};
---

<Layout title={seo.title} description={seo.description}>
  <header class="sticky top-0 z-50 border-b-2 border-[var(--line)] bg-[rgba(226,231,238,0.9)] backdrop-blur-xl">
    <div class="mx-auto flex w-full max-w-5xl items-center justify-between px-6 py-6">
      <div class="text-sm uppercase tracking-[0.36em] text-muted">Articleship Portfolio</div>
      <nav class="hidden items-center gap-7 text-base text-muted md:flex">
        <a href="/" class="hover:text-ink">Home</a>
        <a href="/blog" class="hover:text-ink">Blog</a>
      </nav>
    </div>
  </header>

  <div class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute -top-40 right-0 h-[28rem] w-[28rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(208,106,30,0.38),transparent_70%)] blur-3xl bg-orb"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute bottom-0 left-0 h-[32rem] w-[32rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(36,85,127,0.3),transparent_70%)] blur-3xl bg-orb-delayed"
      aria-hidden="true"
    ></div>

    <main class="mx-auto w-full max-w-4xl px-6 pb-20 pt-12 min-h-screen">
      <a
        href="/blog"
        class="text-xs uppercase tracking-[0.26em] text-muted hover:text-ink"
      >
        ← Back to Blogs
      </a>

      <header class="mt-6 border-b border-line pb-6">
        <p class="text-xs uppercase tracking-[0.26em] text-muted">{frontmatter.tag}</p>
        <h1 class="mt-3 text-4xl font-semibold text-ink">{frontmatter.title}</h1>
        <p class="mt-3 text-sm text-muted">
          {new Date(frontmatter.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "2-digit" })}
        </p>
      </header>

      <article class="blog-content mt-8">
        <Content />
      </article>
    </main>
  </div>
</Layout>
