---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { profile } from "../../data/profile";

export async function getStaticPaths() {
  const modules = import.meta.glob("/src/content/blog/*.md", { eager: true });
  return Object.values(modules)
    .map((mod) => mod.frontmatter?.slug)
    .filter(Boolean)
    .map((slug) => ({ params: { slug } }));
}

const modules = import.meta.glob("/src/content/blog/*.md", { eager: true });
const postModule = Object.values(modules).find(
  (mod) => mod.frontmatter?.slug === Astro.params.slug
);
if (!postModule) {
  throw new Error(`Post not found for slug: ${Astro.params.slug}`);
}
const { Content, frontmatter } = postModule;

const seo = {
  title: `${frontmatter.title} | ${profile.content.seo.postTitleSuffix}`,
  description: frontmatter.summary
};
---

<Layout title={seo.title} description={seo.description}>
  <header class="sticky top-0 z-50 border-b-[2.5px] border-[var(--line)] bg-[rgba(255,255,255,0.92)] backdrop-blur-xl">
    <div class="mx-auto flex w-full max-w-5xl items-center justify-between px-6 py-6">
      <a href="/" class="text-sm uppercase tracking-[0.36em] text-muted">{profile.content.site.brand}</a>
      <nav class="hidden items-center gap-7 text-base text-muted md:flex">
        <a href="/" class="hover:text-ink">{profile.content.site.nav.home}</a>
        <a href="/blog" class="hover:text-ink">{profile.content.site.nav.blog}</a>
      </nav>
    </div>
  </header>

  <div class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute -top-40 right-0 h-[28rem] w-[28rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(255,122,0,0.32),transparent_70%)] blur-3xl bg-orb"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute bottom-0 left-0 h-[32rem] w-[32rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(0,0,0,0.12),transparent_70%)] blur-3xl bg-orb-delayed"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute bottom-10 right-10 h-[18rem] w-[18rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(0,0,0,0.08),transparent_70%)] blur-3xl bg-orb-delayed"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute top-10 left-10 h-[16rem] w-[16rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(255,122,0,0.24),transparent_70%)] blur-3xl bg-orb"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute bottom-24 left-1/3 h-[22rem] w-[22rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(0,0,0,0.09),transparent_70%)] blur-3xl bg-orb-delayed"
      aria-hidden="true"
    ></div>

    <main class="mx-auto w-full max-w-4xl px-6 pb-20 pt-12 min-h-screen">
      <a
        href="/blog"
        class="text-xs uppercase tracking-[0.26em] text-muted hover:text-ink"
      >
        ← {profile.content.blog.backLabel}
      </a>

      <header class="mt-6 border-b border-line pb-6">
        <p class="text-xs uppercase tracking-[0.26em] text-muted">{frontmatter.tag}</p>
        <h1 class="mt-3 text-4xl font-semibold text-ink">{frontmatter.title}</h1>
        <p class="mt-3 text-sm text-muted">
          {new Date(frontmatter.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "2-digit" })}
        </p>
      </header>

      <article class="blog-content mt-8">
        <Content />
      </article>
    </main>
  </div>
</Layout>
