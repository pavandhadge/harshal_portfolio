---
import Layout from "../layouts/Layout.astro";

const profile = {
  name: "Your Name",
  title: "CA Inter Qualified | Articleship Candidate",
  location: "City, State",
  contactEmail: "youremail@example.com",
  contactPhone: "+91 90000 00000",
  linkedIn: "https://www.linkedin.com/in/your-handle",
  resumeUrl: "/resume.pdf",
  summary:
    "Recently cleared CA Intermediate. Looking for a structured articleship where I can apply strong fundamentals in Accounting, Taxation, Audit, and Corporate Law while learning from high-standards practice.",
  availability: "Immediate",
  interests: ["Statutory Audit", "Tax Compliance", "Internal Audit", "GST", "ROC Filings"],
  strengths: [
    "Financial reporting and finalization",
    "GST computation and returns",
    "Audit documentation and vouching",
    "Company law basics and ROC",
    "Excel-based reconciliation"
  ],
  education: [
    {
      title: "CA Intermediate",
      subtitle: "Cleared in 2024 (Group I & II)",
      detail: "Strong performance in Accounting, Taxation, and Auditing."
    },
    {
      title: "B.Com (Commerce)",
      subtitle: "University Name, 2023",
      detail: "Focused on Financial Accounting, Costing, and Business Law."
    }
  ],
  certifications: [
    "MS Excel for Finance (Advanced)",
    "GST Practitioner Workshop",
    "Tally Prime Fundamentals",
    "Communication Skills for Client Work"
  ],
  languages: ["English", "Hindi", "Marathi"],
  generalSkills: [
    "Accounting Standards (AS) basics",
    "TDS/TCS computation and compliance",
    "GST reconciliations and return preparation",
    "ROC forms and corporate compliance awareness",
    "Audit planning and working paper discipline"
  ]
};

const seo = {
  title: `${profile.name} | CA Articleship Portfolio`,
  description:
    "CA Inter qualified candidate seeking articleship. Fundamentals in accounting, audit, taxation, and corporate law."
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  description: profile.summary,
  jobTitle: "CA Articleship Candidate",
  email: profile.contactEmail,
  telephone: profile.contactPhone,
  address: {
    "@type": "PostalAddress",
    addressLocality: profile.location
  },
  url: "https://example.com/"
};
---

<Layout title={seo.title} description={seo.description}>
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify(jsonLd)}</script>
  </Fragment>

  <div class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute -top-32 right-0 h-96 w-96 rounded-full bg-[radial-gradient(circle_at_center,rgba(196,139,63,0.35),transparent_70%)] blur-3xl"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute bottom-0 left-0 h-[32rem] w-[32rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(31,45,58,0.25),transparent_70%)] blur-3xl"
      aria-hidden="true"
    ></div>

    <header class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 pb-6 pt-10">
      <div class="flex items-center gap-3 text-xs uppercase tracking-[0.36em] text-muted">
        <span class="h-2 w-2 rounded-full bg-[var(--accent)]"></span>
        Articleship Portfolio
      </div>
      <nav class="hidden items-center gap-6 text-sm text-muted md:flex">
        <a href="#about" class="hover:text-ink">About</a>
        <a href="#skills" class="hover:text-ink">Skills</a>
        <a href="#education" class="hover:text-ink">Education</a>
        <a href="#contact" class="hover:text-ink">Contact</a>
        <a href="/blogs" class="hover:text-ink">Blogs</a>
      </nav>
    </header>

    <main class="mx-auto w-full max-w-6xl px-6 pb-20">
      <section class="grid items-center gap-10 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="space-y-6">
          <p class="inline-flex items-center gap-2 rounded-full border border-line bg-card px-4 py-2 text-xs uppercase tracking-[0.32em] text-muted shadow-soft">
            CA Inter Qualified
          </p>
          <div class="space-y-4">
            <h1 class="text-balance text-4xl font-semibold leading-tight text-ink sm:text-5xl lg:text-6xl animate-fade-up">
              {profile.name}
            </h1>
            <p class="text-balance text-lg text-muted sm:text-xl animate-fade-up-delay">
              {profile.title} based in {profile.location}. I am actively seeking a CA articleship role focused on
              structured learning, client exposure, and precise financial execution.
            </p>
          </div>
          <div class="flex flex-wrap gap-4 animate-fade-up-delay-lg">
            <a
              href={`mailto:${profile.contactEmail}`}
              class="rounded-full bg-[var(--steel)] px-6 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-white transition hover:bg-[var(--accent-deep)]"
            >
              Email Me
            </a>
            <a
              href={profile.resumeUrl}
              class="rounded-full border border-line px-6 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-ink transition hover:border-[var(--accent)] hover:text-[var(--accent)]"
              download
            >
              Download Resume
            </a>
          </div>
        </div>

        <div class="space-y-6">
          <div class="rounded-3xl border border-line bg-card p-6 shadow-soft animate-reveal">
            <div class="flex items-start justify-between">
              <div>
                <p class="text-xs uppercase tracking-[0.26em] text-muted">Availability</p>
                <p class="mt-2 text-2xl font-semibold">{profile.availability}</p>
              </div>
              <div class="h-12 w-12 rounded-2xl bg-[var(--accent)]/15"></div>
            </div>
            <p class="mt-4 text-sm text-muted">
              Available for audit, taxation, and compliance-focused assignments with mentoring support and exposure to
              real client work.
            </p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-2xl border border-line bg-card p-5">
              <p class="text-xs uppercase tracking-[0.26em] text-muted">Core Strength</p>
              <p class="mt-3 text-lg font-semibold">Accounting & Finalization</p>
            </div>
            <div class="rounded-2xl border border-line bg-card p-5">
              <p class="text-xs uppercase tracking-[0.26em] text-muted">Core Strength</p>
              <p class="mt-3 text-lg font-semibold">Audit Documentation</p>
            </div>
          </div>
        </div>
      </section>

      <section id="about" class="mt-16 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="rounded-3xl border border-line bg-card p-8 shadow-soft">
          <h2 class="text-3xl font-semibold">Profile Summary</h2>
          <p class="mt-4 text-base text-muted">{profile.summary}</p>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <div class="rounded-2xl border border-line p-5">
              <p class="text-xs uppercase tracking-[0.26em] text-muted">Location</p>
              <p class="mt-2 text-lg font-semibold">{profile.location}</p>
            </div>
            <div class="rounded-2xl border border-line p-5">
              <p class="text-xs uppercase tracking-[0.26em] text-muted">Contact</p>
              <p class="mt-2 text-lg font-semibold">{profile.contactPhone}</p>
            </div>
          </div>
        </div>

        <div class="space-y-4">
          <div class="rounded-3xl border border-line bg-card p-6">
            <p class="text-xs uppercase tracking-[0.26em] text-muted">Languages</p>
            <h3 class="mt-2 text-2xl font-semibold">Communication</h3>
            <div class="mt-4 flex flex-wrap gap-2">
              {profile.languages.map((lang) => (
                <span
                  class="rounded-full border border-line bg-[var(--paper)] px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-muted"
                  key={lang}
                >
                  {lang}
                </span>
              ))}
            </div>
          </div>
          <div class="rounded-3xl border border-line bg-card p-6">
            <p class="text-xs uppercase tracking-[0.26em] text-muted">Certifications</p>
            <h3 class="mt-2 text-2xl font-semibold">Courses & Workshops</h3>
            <div class="mt-4 grid gap-3">
              {profile.certifications.map((item) => (
                <div class="rounded-2xl border border-line px-4 py-3 text-sm text-muted" key={item}>
                  {item}
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="skills" class="mt-16">
        <div class="rounded-3xl border border-line bg-card p-8 shadow-soft">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <p class="text-xs uppercase tracking-[0.26em] text-muted">Skills</p>
              <h2 class="mt-2 text-3xl font-semibold">Core Competencies</h2>
              <p class="mt-3 max-w-2xl text-sm text-muted">
                Practical knowledge aligned with audit, compliance, and taxation workstreams.
              </p>
            </div>
            <div class="flex flex-wrap gap-2">
              {profile.interests.map((interest) => (
                <span
                  class="rounded-full border border-line bg-[var(--paper)] px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-muted"
                  key={interest}
                >
                  {interest}
                </span>
              ))}
            </div>
          </div>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {profile.strengths.map((strength) => (
              <div class="rounded-2xl border border-line px-5 py-4" key={strength}>
                <p class="text-sm font-semibold text-ink">{strength}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="education" class="mt-16 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="rounded-3xl border border-line bg-card p-8">
          <p class="text-xs uppercase tracking-[0.26em] text-muted">Education</p>
          <h2 class="mt-2 text-3xl font-semibold">Academic Background</h2>
          <p class="mt-4 text-sm text-muted">
            Structured academic foundation with a focus on accounting, tax, audit, and corporate law.
          </p>
          <div class="mt-6 space-y-3 text-sm text-muted">
            <p>Prepared detailed study schedules for CA Inter with regular revision cycles.</p>
            <p>Maintained structured notes and summaries for quick recall during assessments.</p>
            <p>Developed a habit of accuracy checks and cross-verification in practical work.</p>
          </div>
        </div>

        <div class="grid gap-4">
          {profile.education.map((item) => (
            <div class="rounded-3xl border border-line bg-card p-6" key={item.title}>
              <p class="text-xs uppercase tracking-[0.26em] text-muted">Qualification</p>
              <h3 class="mt-2 text-2xl font-semibold">{item.title}</h3>
              <p class="mt-1 text-sm text-muted">{item.subtitle}</p>
              <p class="mt-3 text-sm text-muted">{item.detail}</p>
            </div>
          ))}
        </div>
      </section>

      <section id="experience" class="mt-16 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="rounded-3xl border border-line bg-card p-8">
          <p class="text-xs uppercase tracking-[0.26em] text-muted">CA Toolkit</p>
          <h2 class="mt-2 text-3xl font-semibold">General Articleship Strengths</h2>
          <p class="mt-4 text-sm text-muted">
            Comfortable with foundational compliance work and clear documentation standards expected in firms.
          </p>
          <div class="mt-6 grid gap-3">
            {profile.generalSkills.map((item) => (
              <div class="rounded-2xl border border-line px-4 py-3 text-sm text-muted" key={item}>
                {item}
              </div>
            ))}
          </div>
        </div>

        <div class="grid gap-4">
          <div class="rounded-3xl border border-line bg-card p-6">
            <p class="text-xs uppercase tracking-[0.26em] text-muted">Current Focus</p>
            <h3 class="mt-2 text-2xl font-semibold">Technical Refinement</h3>
            <p class="mt-3 text-sm text-muted">
              Practicing GST return filings, audit checklists, and Excel reconciliations to ensure accuracy and efficiency.
            </p>
          </div>
          <div class="rounded-3xl border border-line bg-card p-6">
            <p class="text-xs uppercase tracking-[0.26em] text-muted">Work Ethic</p>
            <h3 class="mt-2 text-2xl font-semibold">Reliable, Detail-Driven</h3>
            <p class="mt-3 text-sm text-muted">
              Comfortable with structured tasks, thorough documentation, and meeting review standards consistently.
            </p>
          </div>
          <div class="rounded-3xl border border-line bg-card p-6">
            <p class="text-xs uppercase tracking-[0.26em] text-muted">Learning Style</p>
            <h3 class="mt-2 text-2xl font-semibold">Curious and Coachable</h3>
            <p class="mt-3 text-sm text-muted">
              Seeking regular feedback to improve technical depth and client communication.
            </p>
          </div>
        </div>
      </section>

      <section id="contact" class="mt-16">
        <div class="rounded-3xl border border-line bg-[var(--steel)] px-8 py-10 text-white shadow-soft">
          <div class="flex flex-wrap items-center justify-between gap-6">
            <div>
              <p class="text-xs uppercase tracking-[0.26em] text-white/70">Contact</p>
              <h2 class="mt-2 text-3xl font-semibold">Open to Articleship Discussions</h2>
              <p class="mt-3 max-w-2xl text-sm text-white/70">
                Available for interviews and ready to contribute to audit, taxation, and compliance engagements.
              </p>
            </div>
            <div class="flex flex-col gap-3">
              <a
                href={`mailto:${profile.contactEmail}`}
                class="rounded-full bg-white px-6 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--steel)]"
              >
                {profile.contactEmail}
              </a>
              <a
                href={profile.resumeUrl}
                class="rounded-full border border-white/40 px-6 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-white"
                download
              >
                Download Resume
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="mx-auto w-full max-w-6xl px-6 pb-10 pt-6 text-xs uppercase tracking-[0.24em] text-muted">
      <div class="flex flex-wrap items-center justify-between gap-4 border-t border-line pt-6">
        <span>CA Articleship Portfolio</span>
        <span>Updated March 2026</span>
      </div>
    </footer>
  </div>
</Layout>
