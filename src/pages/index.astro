---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { profile } from "../data/profile";

const seo = {
  title: profile.content.seo.homeTitle,
  description: profile.content.seo.homeDescription
};

const skillGroups = [
  {
    title: profile.content.sections.skills.groupTitles[0],
    items: profile.personal.strengths
  },
  {
    title: profile.content.sections.skills.groupTitles[1],
    items: profile.personal.generalSkills
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.personal.name,
  description: profile.personal.summary,
  jobTitle: profile.personal.jobTitle,
  email: profile.personal.contactEmail,
  address: {
    "@type": "PostalAddress",
    addressLocality: profile.personal.location
  },
  url: profile.content.site.url
};
---

<Layout title={seo.title} description={seo.description}>
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify(jsonLd)}</script>
  </Fragment>

  <header class="sticky top-0 z-50 border-b-[2.5px] border-[var(--line)] bg-[rgba(255,255,255,0.92)] backdrop-blur-xl">
    <div class="mx-auto flex w-full max-w-5xl items-center justify-between px-6 py-4">

      <!-- Logo -->
      <a href="/" class="text-base font-semibold uppercase tracking-[0.3em] text-muted md:text-sm">
        {profile.content.site.brand}
      </a>

      <!-- Mobile Button -->
      <button
        type="button"
        onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
        class="flex h-10 w-10 items-center justify-center text-2xl text-muted md:hidden"
        aria-label="Open navigation"
      >
        ☰
      </button>

      <!-- Desktop Navigation -->
      <nav class="hidden items-center gap-7 text-base text-muted md:flex">
        <a href="#about" class="hover:text-ink">{profile.content.site.nav.about}</a>
        <a href="#skills" class="text-accent-strong hover:text-ink">{profile.content.site.nav.skills}</a>
        <a href="#education" class="hover:text-ink">{profile.content.site.nav.education}</a>
        <a href="#contact" class="hover:text-ink">{profile.content.site.nav.contact}</a>
        <a href="/blog" class="hover:text-ink">{profile.content.site.nav.blog}</a>
      </nav>

    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden border-t border-[var(--line)] md:hidden">
      <nav class="flex flex-col gap-4 px-6 py-5 text-base text-muted">
        <a href="#about" class="hover:text-ink">{profile.content.site.nav.about}</a>
        <a href="#skills" class="hover:text-ink">{profile.content.site.nav.skills}</a>
        <a href="#education" class="hover:text-ink">{profile.content.site.nav.education}</a>
        <a href="#contact" class="hover:text-ink">{profile.content.site.nav.contact}</a>
        <a href="/blog" class="hover:text-ink">{profile.content.site.nav.blog}</a>
      </nav>
    </div>
  </header>

  <div class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute -top-40 right-0 h-[28rem] w-[28rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(255,122,0,0.32),transparent_70%)] blur-3xl bg-orb"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute bottom-0 left-0 h-[32rem] w-[32rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(0,0,0,0.12),transparent_70%)] blur-3xl bg-orb-delayed"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute bottom-10 right-10 h-[18rem] w-[18rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(0,0,0,0.08),transparent_70%)] blur-3xl bg-orb-delayed"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute top-10 left-10 h-[16rem] w-[16rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(255,122,0,0.24),transparent_70%)] blur-3xl bg-orb"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute bottom-24 left-1/3 h-[22rem] w-[22rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(0,0,0,0.09),transparent_70%)] blur-3xl bg-orb-delayed"
      aria-hidden="true"
    ></div>

    <main class="mx-auto w-full max-w-5xl px-6 pb-24 pt-16 sm:pt-20">
        <section class="grid items-center gap-12 lg:grid-cols-[1.15fr_0.85fr]">

          <!-- Image -->
          <div class="flex justify-center order-1 lg:order-2">
            <div class="relative rounded-full border-[8px] border-[var(--line)]">
              <img
                src={profile.personal.photoUrl}
                alt={`${profile.personal.name} portrait`}
                class="h-[200px] w-[200px] rounded-full object-cover"
                loading="lazy"
              />
            </div>
          </div>

          <!-- Text -->
          <div class="space-y-7 order-2 lg:order-1 text-center lg:text-left">

            <div class="space-y-4">
              <h1 class="text-balance text-4xl font-semibold leading-tight text-ink sm:text-5xl lg:text-6xl">
                <span class="text-accent-strong">{profile.personal.name}</span>
                <span class="mt-3 block text-xs uppercase tracking-[0.4em] text-muted">
                  {profile.content.hero.badge}
                </span>
              </h1>

              <p class="text-balance text-lg text-muted sm:text-xl">
                {profile.content.hero.intro}
              </p>
            </div>

            <div class="flex flex-wrap justify-center gap-4 lg:justify-start">
              <a
                href={`mailto:${profile.personal.contactEmail}`}
                class="w-full rounded-full bg-[var(--steel)] px-6 py-3 text-center text-xs font-semibold uppercase tracking-[0.22em] text-white transition hover:bg-[var(--accent-deep)] sm:w-auto"
              >
                {profile.content.hero.ctaEmailLabel}
              </a>

              <a
                href={profile.personal.resumeUrl}
                class="w-full rounded-full border border-line px-6 py-3 text-center text-xs font-semibold uppercase tracking-[0.22em] text-ink transition hover:border-[var(--accent)] hover:text-[var(--accent)] sm:w-auto"
                download
              >
                {profile.content.hero.ctaResumeLabel}
              </a>
            </div>

          </div>

        </section>

      <section id="about" class="mt-20 border-t border-line pt-12">
        <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr]">
          <div class="order-2 lg:order-1">
            <p class="text-xs uppercase tracking-[0.32em] text-muted">{profile.content.about.label}</p>
            <h2 class="mt-3 text-3xl font-semibold">{profile.content.about.title}</h2>
            <p class="mt-4 text-base text-muted">{profile.personal.summary}</p>
            <div class="mt-6 grid gap-4 sm:grid-cols-2">
              <div class="rounded-2xl border border-line p-4">
                <p class="text-xs uppercase tracking-[0.26em] text-muted">{profile.content.about.locationLabel}</p>
                <p class="mt-2 text-sm font-semibold text-ink">{profile.personal.location}</p>
              </div>
              <div class="rounded-2xl border border-line p-4">
                <p class="text-xs uppercase tracking-[0.26em] text-muted">{profile.content.about.contactLabel}</p>
              <p class="mt-2 text-sm font-semibold text-ink">{profile.personal.contactEmail}</p>
              </div>
            </div>
          </div>
          <div class="rounded-3xl border border-line bg-card p-7 shadow-soft order-1 lg:order-2">
            <div>
              <p class="text-xs uppercase tracking-[0.26em] text-muted">{profile.content.about.availabilityLabel}</p>
              <p class="mt-2 text-2xl font-semibold text-ink">{profile.personal.availability}</p>
              <p class="mt-2 text-sm text-muted">
                {profile.content.about.availabilityNote}
              </p>
            </div>
            <div class="border-t border-line pt-5">
              <p class="text-xs uppercase tracking-[0.26em] text-muted">{profile.content.about.contactLabel}</p>
              <p class="mt-2 text-sm text-ink">{profile.personal.contactEmail}</p>
            </div>
            <div class="border-t border-line pt-5">
              <p class="text-xs uppercase tracking-[0.26em] text-muted">{profile.content.about.linkedInLabel}</p>
              <a href={profile.personal.linkedIn} class="mt-2 inline-block text-sm text-ink underline">
                {profile.content.about.linkedInCta}
              </a>
            </div>
          </div>
        </div>
      </section>

      <section id="education" class="mt-20 border-t border-line pt-12">
        <div class="relative">
          <p class="text-xs uppercase tracking-[0.32em] text-muted">{profile.content.sections.education.label}</p>
          <h2 class="mt-3 text-3xl font-semibold">{profile.content.sections.education.title}</h2>
          <p class="mt-4 text-sm text-muted">{profile.content.sections.education.intro}</p>
          <div class="mt-10 space-y-8 md:space-y-10">
            {profile.personal.education.map((item) => (
              <div class="relative grid gap-6 md:grid-cols-[auto_1fr]" key={item.title}>
                <div class="relative hidden items-center justify-center md:flex md:pt-1">
                  <span class="absolute left-1/2 top-0 h-full w-px -translate-x-1/2 bg-[var(--line)]"></span>
                  <span class="relative z-10 h-3 w-3 rounded-full border-2 border-[var(--accent)] bg-[var(--paper)]"></span>
                </div>
                <div class="relative rounded-2xl border border-line bg-card p-6 shadow-soft">
                  <span class="absolute left-6 top-0 h-2.5 w-2.5 -translate-y-1/2 rounded-full border-2 border-[var(--accent)] bg-[var(--paper)] md:hidden"></span>
                  <p class="text-xs uppercase tracking-[0.26em] text-muted">{profile.content.sections.education.itemLabel}</p>
                  <h3 class="mt-2 text-xl font-semibold text-ink">{item.title}</h3>
                  <p class="mt-1 text-sm text-muted">{item.subtitle}</p>
                  <p class="mt-3 text-sm text-muted">{item.detail}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="skills" class="mt-20 border-t border-line pt-12">
        <div>
          <p class="text-xs uppercase tracking-[0.32em] text-muted">{profile.content.sections.skills.label}</p>
          <h2 class="mt-3 text-3xl font-semibold">{profile.content.sections.skills.title}</h2>
          <p class="mt-4 max-w-3xl text-sm text-muted">{profile.content.sections.skills.intro}</p>
          <div class="mt-8 grid gap-8 md:grid-cols-2">
            {skillGroups.map((group) => (
              <div class="border-l border-line pl-6" key={group.title}>
                <h3 class="text-lg font-semibold text-ink">{group.title}</h3>
                <ul class="mt-4 space-y-3 text-[15px] text-muted">
                  {group.items.map((item) => (
                    <li class="flex items-start gap-3" key={item}>
                      <span class="mt-2 h-1.5 w-1.5 rounded-full bg-[var(--accent)]"></span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="certifications" class="mt-20 border-t border-line pt-12">
        <div>
          <p class="text-xs uppercase tracking-[0.32em] text-muted">{profile.content.sections.certifications.label}</p>
          <h2 class="mt-3 text-3xl font-semibold">{profile.content.sections.certifications.title}</h2>
          <p class="mt-4 text-sm text-muted">{profile.content.sections.certifications.intro}</p>
          <div class="mt-8 space-y-3">
            {profile.personal.certifications.map((item) => (
              <div
                class="flex flex-col gap-2 border-b border-line/70 pb-3 text-sm text-muted sm:flex-row sm:items-center sm:justify-between"
                key={item.name}
              >
                <div class="flex items-center gap-3">
                  <span class="h-1.5 w-1.5 rounded-full bg-[var(--accent)]"></span>
                  <a href={item.url} class="group font-semibold text-ink">
                    {item.name}
                    <span class="ml-2 inline-block text-xs transition group-hover:-translate-y-0.5 group-hover:translate-x-0.5">
                      {profile.content.sections.certifications.linkIcon}
                    </span>
                  </a>
                </div>
                <div class="pl-4 text-xs uppercase tracking-[0.26em] text-muted sm:pl-0">{item.date}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="details" class="mt-20 border-t border-line pt-12">
        <div>
          <p class="text-xs uppercase tracking-[0.32em] text-muted">{profile.content.sections.details.label}</p>
          <h2 class="mt-3 text-3xl font-semibold">{profile.content.sections.details.title}</h2>
        </div>
        <div class="mt-6 grid gap-6 lg:grid-cols-2">
          <div class="rounded-2xl border border-line bg-card p-6">
            <p class="text-xs uppercase tracking-[0.26em] text-muted">{profile.content.sections.details.languagesLabel}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {profile.personal.languages.map((lang) => (
                <span
                  class="rounded-full border border-line bg-[var(--paper)] px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-muted"
                  key={lang}
                >
                  {lang}
                </span>
              ))}
            </div>
          </div>
          <div class="rounded-2xl border border-line bg-card p-6">
            <p class="text-xs uppercase tracking-[0.26em] text-muted">{profile.content.sections.details.interestsLabel}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {profile.personal.interests.map((interest) => (
                <span
                  class="rounded-full border border-line bg-[var(--paper)] px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-muted"
                  key={interest}
                >
                  {interest}
                </span>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="contact" class="mt-20 border-t border-line pt-12">
        <div class="rounded-3xl border border-line bg-card p-8 shadow-soft md:p-10">
          <div class="flex flex-wrap items-center justify-between gap-6">
            <div>
              <p class="text-xs uppercase tracking-[0.26em] text-muted">{profile.content.sections.contact.label}</p>
              <h2 class="mt-3 text-3xl font-semibold text-ink">{profile.content.sections.contact.title}</h2>
              <p class="mt-3 max-w-2xl text-sm text-muted">{profile.content.sections.contact.intro}</p>
            </div>
            <div class="flex w-full flex-col gap-3 sm:w-auto">
              <a
                href={`mailto:${profile.personal.contactEmail}`}
                class="rounded-full bg-[var(--steel)] px-6 py-3 text-center text-xs font-semibold uppercase tracking-[0.22em] text-white transition hover:bg-[var(--accent-deep)] hover:shadow-[0_8px_24px_rgba(11,19,25,0.25)]"
              >
                {profile.personal.contactEmail}
              </a>
              <a
                href={profile.personal.resumeUrl}
                class="rounded-full border border-line px-6 py-3 text-center text-xs font-semibold uppercase tracking-[0.22em] text-ink transition hover:border-[var(--accent)] hover:text-[var(--accent)] hover:shadow-[0_8px_24px_rgba(255,122,0,0.18)]"
                download
              >
                {profile.content.hero.ctaResumeLabel}
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="mx-auto w-full max-w-5xl px-6 pb-12 pt-8 text-xs uppercase tracking-[0.24em] text-muted">
      <div class="flex flex-wrap items-center justify-between gap-4 border-t border-line pt-6">
        <span>{profile.content.site.footerNote}</span>
        <!-- <span>Updated March 2026</span> -->
      </div>
    </footer>
  </div>
</Layout>
