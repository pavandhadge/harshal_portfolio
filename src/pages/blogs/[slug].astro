---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const seo = {
  title: `${post.data.title} | Blog | CA Articleship Portfolio`,
  description: post.data.summary
};
---

<Layout title={seo.title} description={seo.description}>
  <div class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute -top-40 right-0 h-[26rem] w-[26rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(196,139,63,0.28),transparent_70%)] blur-3xl"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute bottom-0 left-0 h-[28rem] w-[28rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(31,45,58,0.2),transparent_70%)] blur-3xl"
      aria-hidden="true"
    ></div>

    <main class="mx-auto w-full max-w-4xl px-6 pb-20 pt-12">
      <a
        href="/blogs"
        class="text-xs uppercase tracking-[0.26em] text-muted hover:text-ink"
      >
        ← Back to Blogs
      </a>

      <header class="mt-6 border-b border-line pb-6">
        <p class="text-xs uppercase tracking-[0.26em] text-muted">{post.data.tag}</p>
        <h1 class="mt-3 text-4xl font-semibold text-ink">{post.data.title}</h1>
        <p class="mt-3 text-sm text-muted">
          {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "2-digit" })}
        </p>
      </header>

      <article class="blog-content mt-8">
        <Content />
      </article>
    </main>
  </div>
</Layout>
