---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const PAGE_SIZE = 10;

const allPosts = await getCollection("blog");
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

export function getStaticPaths() {
  const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
  return Array.from({ length: totalPages }, (_, index) => ({
    params: { page: String(index + 1) }
  }));
}

const currentPage = Number(Astro.params.page ?? "1");
const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
const start = (currentPage - 1) * PAGE_SIZE;
const pagePosts = posts.slice(start, start + PAGE_SIZE);

const seo = {
  title: `Blogs | Page ${currentPage} | CA Articleship Portfolio`,
  description: "Short notes on audit, GST, compliance, and articleship preparation."
};
---

<Layout title={seo.title} description={seo.description}>
  <div class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute -top-40 right-0 h-[26rem] w-[26rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(210,119,44,0.28),transparent_70%)] blur-3xl bg-orb"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute bottom-0 left-0 h-[30rem] w-[30rem] rounded-full bg-[radial-gradient(circle_at_center,rgba(43,95,135,0.22),transparent_70%)] blur-3xl bg-orb-delayed"
      aria-hidden="true"
    ></div>

    <main class="mx-auto w-full max-w-5xl px-6 pb-20 pt-12">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <p class="text-xs uppercase tracking-[0.32em] text-muted">Blog</p>
          <h1 class="mt-3 text-4xl font-semibold">Insights & Notes</h1>
          <p class="mt-3 max-w-2xl text-sm text-muted">
            Short, practical notes on audit, GST, and preparing for a high-impact articleship.
          </p>
        </div>
        <a
          href="/"
          class="rounded-full border border-line px-5 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-ink"
        >
          Back to Home
        </a>
      </div>

      <div class="mt-10 grid gap-6">
        {pagePosts.map((post) => (
          <article class="rounded-2xl border border-line bg-card p-7 shadow-soft" key={post.slug}>
            <div class="flex flex-wrap items-center justify-between gap-4">
              <p class="text-xs uppercase tracking-[0.26em] text-muted">{post.data.tag}</p>
              <p class="text-xs uppercase tracking-[0.26em] text-muted">
                {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "2-digit" })}
              </p>
            </div>
            <h2 class="mt-3 text-2xl font-semibold text-ink">
              <a href={`/blogs/${post.slug}`} class="hover:text-[var(--accent)]">
                {post.data.title}
              </a>
            </h2>
            <p class="mt-3 text-sm text-muted">{post.data.summary}</p>
          </article>
        ))}
      </div>

      <nav class="mt-12 flex flex-wrap items-center justify-between gap-4 text-xs uppercase tracking-[0.26em] text-muted">
      <a
        href={currentPage > 1 ? `/blogs/${currentPage - 1}` : "#"}
        class:list={[
          "border border-line px-4 py-2",
          currentPage > 1 ? "text-ink" : "pointer-events-none opacity-40"
        ]}
      >
        Previous
      </a>
        <span>Page {currentPage} of {totalPages}</span>
      <a
        href={currentPage < totalPages ? `/blogs/${currentPage + 1}` : "#"}
        class:list={[
          "border border-line px-4 py-2",
          currentPage < totalPages ? "text-ink" : "pointer-events-none opacity-40"
        ]}
      >
        Next
      </a>
      </nav>
    </main>
  </div>
</Layout>
