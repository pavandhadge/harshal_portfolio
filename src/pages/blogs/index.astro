---
import Layout from "../../layouts/Layout.astro";

const posts = [
  {
    title: "What I Learned Clearing CA Inter",
    date: "2026-02-10",
    summary:
      "A concise reflection on study strategy, revision cycles, and what actually made a difference.",
    tag: "Study"
  },
  {
    title: "GST Compliance Checklist for Small Businesses",
    date: "2026-01-18",
    summary:
      "A practical checklist I follow while preparing GST returns and reconciliations.",
    tag: "GST"
  },
  {
    title: "How I Build Audit Working Papers",
    date: "2025-12-22",
    summary:
      "A clear, step-by-step structure for documentation and review readiness.",
    tag: "Audit"
  }
];

const seo = {
  title: "Blogs | CA Articleship Portfolio",
  description: "Short notes on audit, GST, compliance, and articleship preparation."
};
---

<Layout title={seo.title} description={seo.description}>
  <main class="mx-auto w-full max-w-5xl px-6 pb-20 pt-12">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div>
        <p class="text-xs uppercase tracking-[0.32em] text-muted">Blog</p>
        <h1 class="mt-3 text-4xl font-semibold">Insights & Notes</h1>
        <p class="mt-3 max-w-2xl text-sm text-muted">
          Short, practical notes on audit, GST, and preparing for a high-impact articleship.
        </p>
      </div>
      <a
        href="/"
        class="rounded-full border border-line px-5 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-ink"
      >
        Back to Home
      </a>
    </div>

    <div class="mt-10 grid gap-6">
      {posts.map((post) => (
        <article class="rounded-3xl border border-line bg-card p-6 shadow-soft" key={post.title}>
          <div class="flex flex-wrap items-center justify-between gap-4">
            <p class="text-xs uppercase tracking-[0.26em] text-muted">{post.tag}</p>
            <p class="text-xs uppercase tracking-[0.26em] text-muted">{post.date}</p>
          </div>
          <h2 class="mt-3 text-2xl font-semibold">{post.title}</h2>
          <p class="mt-3 text-sm text-muted">{post.summary}</p>
        </article>
      ))}
    </div>
  </main>
</Layout>
