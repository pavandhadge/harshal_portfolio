---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

const {
  title = "CA Articleship Portfolio | Your Name",
  description =
    "CA Inter qualified candidate seeking articleship. Strong fundamentals in Accounting, Taxation, Audit, and Company Law.",
  canonical
} = Astro.props;

const resolvedCanonical = canonical ?? Astro.url?.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {resolvedCanonical ? <link rel="canonical" href={resolvedCanonical} /> : null}
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#1e2b33" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <ClientRouter />

    <script is:inline>
      try {
        const hasSession = sessionStorage.getItem("siteSession");
        const shouldShow = !hasSession;
        document.documentElement.dataset.showLoader = shouldShow ? "true" : "false";
        sessionStorage.setItem("siteSession", "true");
      } catch (e) {
        document.documentElement.dataset.showLoader = "true";
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <slot name="head" />
  </head>
  <body class="bg-paper text-ink">
    <div id="site-loader" class="site-loader" aria-hidden="true">
      <div class="site-loader__inner">
        <span class="site-loader__mark">HE</span>
        <span class="site-loader__name">Harshal Etthar</span>
        <span class="site-loader__role">CA Aspirant</span>
      </div>
    </div>
    <slot />
    <script>
      const loader = document.getElementById("site-loader");
      if (loader) {
        const shouldShow =
          document.documentElement.dataset.showLoader === "true";
        if (!shouldShow) {
          loader.remove();
        } else {
          const minDuration = 400;
          const maxDuration = 1500;
          const startedAt = Date.now();
          let hidden = false;
          const hideLoader = () => {
            if (hidden) return;
            hidden = true;
            const elapsed = Date.now() - startedAt;
            const remaining = Math.max(0, minDuration - elapsed);
            setTimeout(() => {
              loader.classList.add("site-loader--hide");
              setTimeout(() => loader.remove(), 650);
            }, remaining);
          };
          if (document.readyState === "interactive" || document.readyState === "complete") {
            hideLoader();
          } else {
            document.addEventListener("DOMContentLoaded", hideLoader, { once: true });
          }
          setTimeout(hideLoader, maxDuration);
        }
      }
    </script>
  </body>
</html>
